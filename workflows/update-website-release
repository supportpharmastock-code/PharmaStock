name: Update Website After Release

on:
  release:
    types: [published]
  workflow_dispatch:

permissions:
  contents: write

jobs:
  update-website:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout main branch
        uses: actions/checkout@v4
        with:
          ref: main

      - name: Update website version and download links
        env:
          RELEASE_TAG: ${{ github.event.release.tag_name }}
          MANUAL_TAG: ${{ inputs.release_tag }}
          REPOSITORY: ${{ github.repository }}
        run: |
          python3 <<'PY'
          import json
          import os
          import re
          from pathlib import Path

          tag = (os.environ.get("RELEASE_TAG") or "").strip()

          # For manual testing, use the latest published release through GitHub API.
          if not tag:
              import urllib.request
              api_url = f"https://api.github.com/repos/{os.environ['REPOSITORY']}/releases/latest"
              request = urllib.request.Request(
                  api_url,
                  headers={
                      "Accept": "application/vnd.github+json",
                      "User-Agent": "PharmaStock-Website-Updater"
                  }
              )
              with urllib.request.urlopen(request) as response:
                  tag = json.load(response)["tag_name"]

          version = tag[1:] if tag.lower().startswith("v") else tag
          repository = os.environ["REPOSITORY"]
          installer_name = f"PharmaStock-Pro-Setup-{version}.exe"
          download_url = (
              f"https://github.com/{repository}/releases/download/"
              f"{tag}/{installer_name}"
          )
          release_url = f"https://github.com/{repository}/releases/tag/{tag}"

          path = Path("index.html")
          if not path.exists():
              raise SystemExit("index.html was not found in the main branch.")

          html = path.read_text(encoding="utf-8")

          # Update body machine-readable version.
          html, body_count = re.subn(
              r'(<body\b[^>]*\bdata-current-version=["\'])[^"\']*(["\'])',
              rf'\g<1>{version}\g<2>',
              html,
              count=1,
              flags=re.IGNORECASE
          )

          # Update all visible version markers.
          html, visible_count = re.subn(
              r'(<span\b[^>]*\bdata-software-version(?:=["\'][^"\']*["\'])?[^>]*>)'
              r'.*?'
              r'(</span>)',
              rf'\g<1>{version}\g<2>',
              html,
              flags=re.IGNORECASE | re.DOTALL
          )

          # Update every marked installer download link.
          def replace_download_link(match):
              opening = match.group(1)
              quote = match.group(2)
              return f'{opening}{download_url}{quote}'

          html, link_count = re.subn(
              r'(<a\b(?=[^>]*\bdata-download-link\b)[^>]*\bhref=)(["\'])'
              r'[^"\']*'
              r'\2',
              replace_download_link,
              html,
              flags=re.IGNORECASE
          )

          # Update SoftwareApplication structured data values.
          json_block_pattern = re.compile(
              r'(<script\b[^>]*\bid=["\']softwareStructuredData["\'][^>]*>)'
              r'(.*?)'
              r'(</script>)',
              re.IGNORECASE | re.DOTALL
          )
          block_match = json_block_pattern.search(html)

          if not block_match:
              raise SystemExit("softwareStructuredData JSON-LD block was not found.")

          json_text = block_match.group(2).strip()
          data = json.loads(json_text)
          data["softwareVersion"] = version
          data["downloadUrl"] = download_url
          data["installUrl"] = download_url
          data["releaseNotes"] = release_url

          formatted_json = json.dumps(data, ensure_ascii=False, indent=2)
          replacement_block = (
              block_match.group(1)
              + "\n"
              + formatted_json
              + "\n  "
              + block_match.group(3)
          )
          html = (
              html[:block_match.start()]
              + replacement_block
              + html[block_match.end():]
          )

          if body_count != 1:
              raise SystemExit("data-current-version marker was not found exactly once.")
          if visible_count < 1:
              raise SystemExit("No data-software-version markers were found.")
          if link_count < 1:
              raise SystemExit("No data-download-link markers were found.")

          path.write_text(html, encoding="utf-8")

          print(f"Website updated to version {version}")
          print(f"Updated {visible_count} visible version labels")
          print(f"Updated {link_count} installer download links")
          print(f"Installer URL: {download_url}")
          PY

      - name: Commit website update
        run: |
          if git diff --quiet -- index.html; then
            echo "No website changes were needed."
            exit 0
          fi

          TAG="${{ github.event.release.tag_name }}"
          if [ -z "$TAG" ]; then
            TAG="latest release"
          fi

          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add index.html
          git commit -m "Update website for ${TAG}"
          git push origin main
